#include <libdragon.h>
#include <t3d/t3d.h>
#include <t3d/t3dmodel.h>

#include "../types.h"
#include "../engine.h"
#include "../renderer.h"
#include "../data/models.h"
#include "../data/traits.h"
#include "../data/scenes.h"
#include "../iron/object/animation.h"

#if ENGINE_ENABLE_PHYSICS
#include "../oimo/physics.h"
#include "../events/physics_events.h"
#if ENGINE_ENABLE_PHYSICS_DEBUG
#include "../oimo/debug/physics_debug.h"
#endif
#endif

extern rspq_block_t *models_get_dpl(ModelId id);

void scene_{scene_name}_init(ArmScene *scene)
{{
    scene->world.clear_color[0] = {cr};
    scene->world.clear_color[1] = {cg};
    scene->world.clear_color[2] = {cb};
    scene->world.clear_color[3] = 0xFF;

    scene->world.ambient_color[0] = {ar};
    scene->world.ambient_color[1] = {ag};
    scene->world.ambient_color[2] = {ab};
    scene->world.ambient_color[3] = 0xFF;

    static ArmCamera cameras[{camera_count}];
    scene->cameras = cameras;
    scene->camera_count = {camera_count};
    scene->active_camera_id = 0;

    // Forward-declare objects array so camera parent pointers can reference it
    static ArmObject objects[{object_count}];

{cameras_block}

    // Lifecycle flags for cameras are pre-computed at export time

    static ArmLight lights[{light_count}];
    scene->lights = lights;
    scene->light_count = {light_count};

{lights_block}

    // Lifecycle flags for lights are pre-computed at export time

    scene->objects = objects;
    scene->object_count = {object_count};
    scene->active_count = {object_count};  // All objects start active

    // Initialize object pool free list (for runtime recycling)
    static uint16_t free_list[{object_count}];
    scene->free_list = free_list;
    scene->free_count = 0;  // No free slots initially
    scene->free_capacity = {object_count};

    // Initialize active objects list (objects with traits that need updates)
    static uint16_t active_objects[{object_count}];
    scene->active_objects = active_objects;
    scene->active_trait_count = 0;

    // Initialize physics objects list (objects with rigid bodies)
    static uint16_t physics_objects[{physics_object_count}];
    scene->physics_objects = physics_objects;
    scene->physics_count = 0;

    // Initialize animated objects list (objects with skeletal animation)
    static uint16_t animated_objects[{animated_object_count}];
    scene->animated_objects = animated_objects;
    scene->animated_count = 0;

    // Initialize render2d objects list (objects with on_render2d callbacks)
    static uint16_t render2d_objects[{render2d_object_count}];
    scene->render2d_objects = render2d_objects;
    scene->render2d_count = 0;

    // Scene-level flags (computed at export time)
    scene->has_parented_objects = {has_parented_objects};

{objects_block}

    // Build active/animated/render2d lists from pre-computed flags
    // Note: physics_objects is populated AFTER physics_block creates bodies
    for (uint16_t i = 0; i < scene->object_count; i++) {{
        ArmObject *obj = &scene->objects[i];
        if (obj->is_removed) continue;

        // Add to active list if has any update callbacks
        if (obj->lifecycle_flags & (ARM_LIFECYCLE_FIXED_UPDATE | ARM_LIFECYCLE_UPDATE | ARM_LIFECYCLE_LATE_UPDATE)) {{
            scene->active_objects[scene->active_trait_count++] = i;
        }}
        // Add to render2d list if has render2d callback
        if (obj->lifecycle_flags & ARM_LIFECYCLE_RENDER2D) {{
            scene->render2d_objects[scene->render2d_count++] = i;
        }}
        // Add to animated list if has animation
        if (obj->animation) {{
            scene->animated_objects[scene->animated_count++] = i;
        }}
    }}

#if ENGINE_ENABLE_PHYSICS
{physics_block}
    // Re-populate physics list after bodies are created
    scene->physics_count = 0;
    for (uint16_t i = 0; i < scene->object_count; i++) {{
        if (scene->objects[i].rigid_body && !scene->objects[i].is_removed) {{
            scene->physics_objects[scene->physics_count++] = i;
        }}
    }}
{contact_subs_block}
#endif

    scene->trait_count = {scene_trait_count};
    scene->lifecycle_flags = 0;
{scene_traits_block}
}}
