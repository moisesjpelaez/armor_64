// ============================================================================
// Compile-time definition struct
// ============================================================================

typedef struct {{
    const char *sprite_name;
    int16_t pos_x, pos_y;
    int16_t width, height;
    uint8_t anchor;
    bool    scale;
    bool    visible;
    sprite_t *sprite;   // Filled at runtime (sprite_load)
    uint8_t align_h;
    int16_t align_width;
}} UIImageDef;

// ============================================================================
// Anchor helpers (N64 fixed 320x240)
// ============================================================================

static int16_t image_anchor_x(int16_t pos_x, int16_t width, uint8_t anchor) {{
    switch (anchor) {{
        case 1: case 4: case 7: return (320 / 2) - (width / 2) + pos_x;  // CENTER
        case 2: case 5: case 8: return 320 - width + pos_x;               // RIGHT
        default:                return pos_x;
    }}
}}

static int16_t image_anchor_y(int16_t pos_y, int16_t height, uint8_t anchor) {{
    switch (anchor) {{
        case 3: case 4: case 5: return (240 / 2) - (height / 2) + pos_y;  // MIDDLE
        case 6: case 7: case 8: return 240 - height + pos_y;               // BOTTOM
        default:                return pos_y;
    }}
}}

