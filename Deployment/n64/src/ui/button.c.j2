/* N64 Exporter - UI Button implementation
 * Auto-generated from Koui canvas data. Do not edit directly.
 * Template: button.c.j2
 *
 * Replicates Koui Button + EventHandler behavior 1:1:
 *
 *   Focus navigation (EventHandler.onGamepadButton / onGamepadAxis):
 *   - DPad pressed (value==1.0): if no focus → focusFirstElement(); else navigate focus graph
 *   - Analog stick: threshold-crossing detection (previous value crosses ±0.5) + 0.2s cooldown
 *   - Only DPad/stick directions navigate; A button does NOT navigate
 *   - No auto-focus on scene init — only on first directional input
 *
 *   Button press (Button._onGamepadButton → synthetic _onClick):
 *   - A ButtonDown → isPressed = true  (ClickStart)
 *   - A ButtonUp   → isPressed = false (ClickEnd); _activated = true for one frame
 *
 *   Focus change (Button._onFocus):
 *   - FocusLoose → isPressed = false (non-toggle buttons)
 *
 *   Rendering (Button.draw):
 *   - isPressed → "click" colors
 *   - focused   → "hover" colors
 *   - else      → default colors
 */
#include "button.h"
#include "fonts.h"
#include "../iron/system/input.h"
#include <libdragon.h>
#include <string.h>

#if UI_BUTTON_COUNT > 0

// ============================================================================
// Static pool
// ============================================================================

static UIButton g_buttons[UI_MAX_BUTTONS];
static int      g_button_count  = 0;
static int      g_focused_index = -1;  // -1 = no button focused

// Analog stick previous values for threshold-crossing detection
static float g_stick_prev_x = 0.0f;
static float g_stick_prev_y = 0.0f;

// ============================================================================
// Compile-time definition struct
// ============================================================================

typedef struct {{
    int16_t pos_x, pos_y, width, height;
    // Colors: stored as RGBA components for static init without libdragon macros
    uint8_t bg_r, bg_g, bg_b, bg_a;
    uint8_t border_r, border_g, border_b, border_a;
    uint8_t hover_bg_r, hover_bg_g, hover_bg_b, hover_bg_a;
    uint8_t hover_border_r, hover_border_g, hover_border_b, hover_border_a;
    uint8_t click_bg_r, click_bg_g, click_bg_b, click_bg_a;
    uint8_t click_border_r, click_border_g, click_border_b, click_border_a;
    int8_t  border_size;
    const char *text;
    uint8_t font_id;           // Logical ID → fonts_get_rdpq_id()
    int8_t  font_baseline_offset;
    uint8_t text_style_id;
    uint8_t hover_text_style_id;
    int8_t  focus_up, focus_down, focus_left, focus_right;
    bool    visible;
}} UIButtonDef;

// ============================================================================
// Per-canvas static button definition arrays
