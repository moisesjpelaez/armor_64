// ============================================================================
// Internal load helper
// ============================================================================

static void load_buttons(const UIButtonDef *defs, int count) {{
    for (int i = 0; i < count && g_button_count < UI_MAX_BUTTONS; i++) {{
        const UIButtonDef *def = &defs[i];
        UIButton *btn = &g_buttons[g_button_count++];

        btn->pos_x   = def->pos_x;   btn->pos_y    = def->pos_y;
        btn->width   = def->width;   btn->height   = def->height;

        btn->bg_r = def->bg_r; btn->bg_g = def->bg_g;
        btn->bg_b = def->bg_b; btn->bg_a = def->bg_a;
        btn->border_r = def->border_r; btn->border_g = def->border_g;
        btn->border_b = def->border_b; btn->border_a = def->border_a;

        btn->hover_bg_r = def->hover_bg_r; btn->hover_bg_g = def->hover_bg_g;
        btn->hover_bg_b = def->hover_bg_b; btn->hover_bg_a = def->hover_bg_a;
        btn->hover_border_r = def->hover_border_r; btn->hover_border_g = def->hover_border_g;
        btn->hover_border_b = def->hover_border_b; btn->hover_border_a = def->hover_border_a;

        btn->click_bg_r = def->click_bg_r; btn->click_bg_g = def->click_bg_g;
        btn->click_bg_b = def->click_bg_b; btn->click_bg_a = def->click_bg_a;
        btn->click_border_r = def->click_border_r; btn->click_border_g = def->click_border_g;
        btn->click_border_b = def->click_border_b; btn->click_border_a = def->click_border_a;

        btn->disabled_bg_r = def->disabled_bg_r; btn->disabled_bg_g = def->disabled_bg_g;
        btn->disabled_bg_b = def->disabled_bg_b; btn->disabled_bg_a = def->disabled_bg_a;
        btn->disabled_border_r = def->disabled_border_r; btn->disabled_border_g = def->disabled_border_g;
        btn->disabled_border_b = def->disabled_border_b; btn->disabled_border_a = def->disabled_border_a;

        btn->border_size          = def->border_size;
        btn->font_rdpq_id         = fonts_get_rdpq_id(def->font_id);
        btn->font_baseline_offset = def->font_baseline_offset;
        btn->text_style_id        = def->text_style_id;
        btn->hover_text_style_id  = def->hover_text_style_id;
        btn->focus_up             = def->focus_up;
        btn->focus_down           = def->focus_down;
        btn->focus_left           = def->focus_left;
        btn->focus_right          = def->focus_right;
        btn->visible              = def->visible;
        btn->initial_visible      = def->visible;
        btn->focused              = false;
        btn->disabled             = false;
        btn->isPressed            = false;
        btn->_activated           = false;

        btn->on_pressed       = NULL;  btn->on_pressed_data  = NULL;
        btn->on_released      = NULL;  btn->on_released_data = NULL;
        btn->on_focus         = NULL;  btn->on_focus_data    = NULL;

        if (def->text) {{
            strncpy(btn->text, def->text, UI_BUTTON_TEXT_SIZE - 1);
            btn->text[UI_BUTTON_TEXT_SIZE - 1] = '\0';
        }} else {{
            btn->text[0] = '\0';
        }}
    }}
}}

